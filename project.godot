; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Together"
run/main_scene="uid://b2pf1jf4yekyt"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0.8256507, 0.9999996, 0.8285515, 1)
boot_splash/image="uid://drjgml63q7kr8"
config/icon="uid://c0qvf0gq5idkr"

[autoload]

__InkRuntime="*uid://co6cdriqgy3v2"
SceneCache="*uid://c3pujqtraagig"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/inkgd/plugin.cfg")

[file_customization]

folder_colors={
"res://Entities/": "orange",
"res://Objects/": "red",
"res://Scenes/": "green",
"res://Sound/": "blue"
}

[global_group]

"Player Attack"=""
"Enemy Attack"=""
Enemy=""
Player=""
ProjectileEnemy=""
AoE_Enemy=""
MeleeEnemy=""
BoundaryLeft=""
BoundaryRight=""
BoundaryTop=""
BoundaryBottom=""
DisappearOnContact=""
Elvyria=""
Ryl=""

[inkgd]

register_templates=true

