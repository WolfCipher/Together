[node name="EmitDialogInRange" parent="Animals" unique_id=57698111 instance=ExtResource("24_etuld")]
position = Vector2(4196, 508)
scale = Vector2(2, 2)
dialog_list = [["elvyria", 0, "Aw. They followed us here.", 7], ["ryl", 0, "...Yes. They're friends of mine.", 5], ["ryl", 0, "Please, go back to Tamewood.", 3]]

[node name="Silas" parent="." unique_id=601485998 instance=ExtResource("26_f80nq")]
position = Vector2(8411, -6270)

[node name="EmitDialogInRange" parent="Silas" unique_id=584359162 instance=ExtResource("24_etuld")]
dialog_list = [["silas", 0, "Ah, a couple of intrepid young adventurers.", 9], ["silas", 0, "Vyerity told me to expect you.", 7], ["elvyria", 0, "How'd she do that?", 5], ["ryl", 0, "She always finds a way. Should've seen this coming.", 3]]
send_to_scene_after_completion = true
next_scene = "res://Ink/Scenes/silas_dialog.tscn"

[node name="EmitDialogInRange" parent="." unique_id=869890286 instance=ExtResource("24_etuld")]
position = Vector2(4721, -1972)
scale = Vector2(3, 3)
dialog_list = [["ryl", 0, "Wait a moment, Elvyria. What's that ahead of us on the path?", 7], ["elvyria", 0, "Not again! Prepare yourself, Ryl!", 5], ["ryl", 0, "Grr...", 3]]

[node name="EmitDialogInRange2" parent="." unique_id=1938153284 instance=ExtResource("24_etuld")]
position = Vector2(548, 496)
dialog_list = [["ryl", 0, "Wow, I still can't believe Vyerity lended us her gear! I feel stronger already!", 10], ["elvyria", 0, "Hey, thanks for coming with me, Ryl. It's nice to have a friend.", 8], ["ryl", 0, "No problem! I always wanted to travel and training with you has been fun!", 6], ["elvyria", 0, "Same here! I enjoy enhancing your arrows with my melee and vice versa!", 4], ["ryl", 0, "My favorite tactic is shooting together in all directions!", 2]]
