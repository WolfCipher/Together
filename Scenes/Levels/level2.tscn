[node name="EmitDialogInRange" parent="Dialog/Butterfly" unique_id=367136165 instance=ExtResource("21_b2fon")]
z_index = 10
position = Vector2(-382.93164, 611.2864)
rotation = -0.4693181
scale = Vector2(1.9999998, 1.9999998)
dialog_list = [["elvyria", 0, "That's the butterfly!", 7], ["ryl", 0, "The butterfly?", 5], ["elvyria", 0, "It led me to the Sacred Gate!", 3], ["ryl", 0, "Sacred... Gate?", 1], ["elvyria", 0, "Y'know, the gate between Mystia and the Dullworld?", 11], ["ryl", 0, "Mystia... Like in the fairytales?", 9], ["elvyria", 0, "Fairytales? Noooo?", 7], ["ryl", 0, "...We should go visit Vyerity, my mentor. She travels a lot and may be able to help you.", 5], ["ryl", 0, "She lives in the northernmost house in the village.", 3]]

[node name="EmitDialogInRangeHome" parent="Dialog" unique_id=649674615 instance=ExtResource("21_b2fon")]
