[node name="EmitDialogInRange2" parent="Dialog" unique_id=443726311 instance=ExtResource("21_b2fon")]
position = Vector2(1528, -340)
dialog_list = [["elvyria", 0, "Wow, so this is the Dullworld. The flora here is so different!", 5], ["ryl", 0, "Dull... world...", 3], ["elvyria", 0, "We call it that back home.", 1]]

[node name="AzureBerries" parent="Dialog" unique_id=1988277302 instance=ExtResource("23_pwvbg")]
position = Vector2(4093, -348)

[node name="EmitDialogInRange3" parent="Dialog/AzureBerries" unique_id=189208871 instance=ExtResource("21_b2fon")]
position = Vector2(0, 45)
dialog_list = [["elvyria", 0, "That's so pretty!", 10], ["ryl", 0, "It's azureberries!", 8], ["ryl", 0, "Tamewood's fairytales reference them a lot!", 6], ["ryl", 0, "They're said to have healing powers!", 4], ["ryl", 0, "...I use them for dye, though.", 2]]

[node name="Butterfly" parent="Dialog" unique_id=1961194005 instance=ExtResource("25_t6y87")]
